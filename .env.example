# Copy to `.env` and fill in before deploying the contract or connecting locally.
# NEVER commit the real `.env`.

# --- Frontend (Vite exposes any VITE_* var to the client bundle) ---

# Sepolia RPC used by the browser to read chamber state without a wallet.
# A public endpoint is fine for read-only; swap in a paid one if you hit rate limits.
VITE_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# EVMHistorian contract address on Sepolia. Filled in after deployment.
# v2 contract is an ERC-721 — re-deploy is required if you upgraded from v1.
VITE_HISTORIAN_ADDRESS=0x0000000000000000000000000000000000000000

# --- Contract deploy (used ONLY by forge create, never shipped to browser) ---

# Dev wallet private key (Sepolia only — NEVER put mainnet keys here).
DEPLOYER_PRIVATE_KEY=0xYOUR_SEPOLIA_DEV_KEY_HERE

# RPC used by forge create for deployment. Can be the same as VITE_SEPOLIA_RPC.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Etherscan key for contract verification (optional, nice-to-have).
ETHERSCAN_API_KEY=
